@* Chatbot Mini - Estilo Círculo Amarillo *@
<div class="chatbot-float-container @(isChatOpen ? "open" : "")">
    @if (!isChatOpen)
    {
        <button class="chatbot-float-btn" @onclick="ToggleChat">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chat-icon-main">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chat-icon-back">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
        </button>
    }
    else
    {
        <div class="chatbot-window">
            <div class="chatbot-window-header">
                <span>Asistente GS-Protect</span>
                <button class="chat-close-btn" @onclick="ToggleChat">✕</button>
            </div>
            <div class="messages-area-mini" id="chatMessages">
                <div class="chat-message-mini bot">
                    <div class="message-content-mini">
                        Buenos días, soy el asistente virtual de GS-Protect & Clean. ¿En qué servicio puedo ayudarle hoy? (Seguridad / Limpieza)
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(userMessage))
                {
                    <div class="chat-message-mini user">
                        <div class="message-content-mini">
                            @userMessage
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(botResponse))
                {
                    <div class="chat-message-mini bot">
                        <div class="message-content-mini">
                            @botResponse
                        </div>
                    </div>
                }
            </div>
            <div class="chat-input-area-mini">
                <input @bind="userMessage"
                       @bind:event="oninput"
                       placeholder="Escribe aquí..."
                       @onkeydown="HandleKeyDown"
                       @onclick:stopPropagation="true" />
                <button @onclick="SendMessage" @onclick:stopPropagation="true">➤</button>
            </div>
        </div>
    }
</div>

<script>
    window.scrollToBottom = (elementId) => {
        const element = document.getElementById(elementId);
        if (element) 
            element.scrollTop = element.scrollHeight;
    };
</script>

@* Code-behind *@
@code {
    private bool isChatOpen = false;
    private string userMessage = "";
    private string botResponse = "";

    private void ToggleChat()
    {
        isChatOpen = !isChatOpen;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userMessage)) return;

        var userInput = userMessage;
        var lowerMsg = userInput.ToLower();

        userMessage = "";

        StateHasChanged();

        await Task.Delay(50);

        await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatMessages");

        if (lowerMsg.Contains("seguridad"))
            botResponse = "Nuestro servicio de seguridad incluye vigilancia 24/7, control de accesos y escoltas. ¿Le gustaría recibir una cotización personalizada para su negocio en Acapulco?";
        else if (lowerMsg.Contains("limpieza"))
            botResponse = "Ofrecemos limpieza profunda, sanitización y mantenimiento de pisos. ¿Qué tipo de instalaciones necesita limpiar? (Hoteles, oficinas, industrias)";
        else
            botResponse = "Por favor, especifique si necesita ayuda con nuestros servicios de Seguridad o Limpieza. Un asesor en Acapulco le contactará en menos de 30 minutos.";

        StateHasChanged();

        await Task.Delay(50);
        await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatMessages");
    }
}